# =============================================================================
# translate.py — Azure Speech Translation (Speech SDK)
# =============================================================================

# Azure Speech 리소스 리전 (예: eastus, westus2, koreacentral)
AZURE_SPEECH_REGION=eastus

# Azure Speech 리소스 ID (전체 ARM 리소스 경로)
# 예: /subscriptions/<sub-id>/resourceGroups/<rg>/providers/Microsoft.CognitiveServices/accounts/<name>
AZURE_SPEECH_RESOURCE_ID=

# =============================================================================
# translate_llmspeech_rest.py / translate_llmspeech_sdk.py — LLM Speech
# =============================================================================

# 옵션 1: API 키 인증 (둘 중 하나만 설정)
AZURE_MAI_SPEECH_API_KEY=
AZURE_MAI_SPEECH_REGION=eastus

# 옵션 2: Azure AD 토큰 인증 (az login 필요, 커스텀 서브도메인 필수)
AZURE_MAI_SPEECH_RESOURCE_ID=

# (선택) 커스텀 엔드포인트 직접 지정
# AZURE_MAI_SPEECH_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com

# =============================================================================
# text_translate.py — Azure AI Translator (외신 텍스트 번역)
# =============================================================================

# AAD 인증용 — 멀티서비스(AIServices) 리소스 ID와 리전.
# 미설정 시 text_translate.py가 위 AZURE_SPEECH_RESOURCE_ID / AZURE_SPEECH_REGION 으로 폴백.
AZURE_TRANSLATOR_REGION=eastus
AZURE_TRANSLATOR_RESOURCE_ID=

# (선택) API 키 인증 시
# AZURE_TRANSLATOR_API_KEY=

# (선택) 커스텀/전용 Translator 엔드포인트 (기본: 글로벌 api.cognitive.microsofttranslator.com)
# AZURE_TRANSLATOR_ENDPOINT=https://api.cognitive.microsofttranslator.com

# =============================================================================
# text_translate.py --engine llm — Azure OpenAI (LLM 텍스트 번역)
# =============================================================================

# LLM 엔진 사용 시. 멀티서비스(AIServices) 리소스에 모델 배포 필요(예: gpt-5.4-mini).
# 엔드포인트 미설정 시 AZURE_SPEECH_RESOURCE_ID로부터 유추. AAD 인증(az login).
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=gpt-5.4-mini
AZURE_OPENAI_API_VERSION=2024-10-21

# (선택) Translator LLM 번역 — text_translate.py --engine translator-llm
# Translator 2026-06-06 경유 GPT 번역. mini/nano 미지원 → gpt-5.1/gpt-5.4 풀모델 배포 필요.
AZURE_TRANSLATOR_LLM_DEPLOYMENT=gpt-5.1
